# Web Push (VAPID) — set these in Netlify dashboard:
# Site settings -> Build & deploy -> Environment -> Environment variables.
# Generate keys once with: npx web-push generate-vapid-keys --json
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:abhishek@usebruno.com

# Same public key exposed to the client build (must match VAPID_PUBLIC_KEY).
# Vite only exposes env vars prefixed with VITE_ to the browser bundle.
VITE_VAPID_PUBLIC_KEY=
